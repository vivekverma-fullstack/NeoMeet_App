# --------------------------------------------------
# NeoMeet Backend - Environment Configuration
# --------------------------------------------------
# Copy this file to ".env" and replace placeholder
# values with your actual credentials.
# Never commit your real .env file to GitHub.
# --------------------------------------------------


# --------------------------------------------------
# Database Configuration
# --------------------------------------------------
# MongoDB Atlas connection string
# Format:
# mongodb+srv://<username>:<password>@<cluster-url>/<database>?retryWrites=true&w=majority

MONGODB_URI=mongodb+srv://your_username:your_password@cluster.mongodb.net/neomeet?retryWrites=true&w=majority


# --------------------------------------------------
# Authentication Configuration
# --------------------------------------------------
# Secret key used to sign JWT tokens
# Use a long, random, unpredictable string in production

JWT_SECRET=replace_with_a_secure_random_string


# --------------------------------------------------
# Server Configuration
# --------------------------------------------------
PORT=8000
NODE_ENV=development


# --------------------------------------------------
# CORS Configuration
# --------------------------------------------------
# Allowed frontend origin for cross-origin requests
# In production, set this to your deployed frontend URL

FRONTEND_URL=http://localhost:3000

# Example production value:
# FRONTEND_URL=https://your-app.vercel.app
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/neomeet
JWT_SECRET=123456
FRONTEND_URL=http://localhost:3000